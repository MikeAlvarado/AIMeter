    },
    "On the Mac, AIMeter reads the login Claude Code already keeps on this computer — read-only. It never modifies or rotates those tokens; Claude Code stays in charge of its own session." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En la Mac, AIMeter lee la sesión que Claude Code ya mantiene en esta computadora — solo lectura. Nunca modifica ni rota esos tokens; Claude Code sigue a cargo de su propia sesión."
          }
        }
      }
    },
